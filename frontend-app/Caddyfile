# PHASE 1: local network access only, internal self-signed cert
# Browser will warn "not trusted" - click Advanced -> Continue, that's expected
# PHASE 2: when ready for external access, swap to the DuckDNS config below

{
    # Use internal self-signed certs for all sites (no Let's Encrypt)
    local_certs
}

https://:443 {
    tls internal

    reverse_proxy /api/* api:8080 {
        header_up X-Forwarded-Proto {http.request.scheme}
        header_up X-Real-IP         {http.request.remote.host}
        header_up X-Forwarded-For   {http.request.remote.host}
    }

    root * /srv
    try_files {path} /index.html
    file_server
}

:80 {
    redir https://{host}{uri} 308
}

